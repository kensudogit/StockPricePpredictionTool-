# Stock Price Prediction Tool — Environment
# Copy to .env and fill in API keys

# --- PostgreSQL ---
POSTGRES_USER=stockai
POSTGRES_PASSWORD=stockai_secret
POSTGRES_DB=stockai
DATABASE_URL=postgresql+asyncpg://stockai:stockai_secret@postgres:5432/stockai
DATABASE_URL_SYNC=postgresql://stockai:stockai_secret@postgres:5432/stockai

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://frontend:3000
SECRET_KEY=change-me-in-production-use-long-random-string
ENVIRONMENT=development

# --- Market Data APIs ---
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=

# --- LLM (OpenAI / Claude / Gemini) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# --- Vector DB ---
VECTOR_BACKEND=pgvector
PINECONE_API_KEY=
WEAVIATE_URL=
MILVUS_URI=
QDRANT_URL=

# --- Broker / Paper Trading ---
TRADING_MODE=paper
BROKER_NAME=paper
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_BASE_URL=
ALPACA_API_KEY=
ALPACA_API_SECRET=
IBKR_HOST=
IBKR_PORT=7497
SBI_API_KEY=
RAKUTEN_API_KEY=
KABUCOM_API_PASSWORD=

# --- Risk Limits ---
MAX_POSITION_PCT=0.10
MAX_DAILY_LOSS_PCT=0.02
MAX_ORDER_NOTIONAL=1000000
DEFAULT_STOP_LOSS_PCT=0.03
DEFAULT_TAKE_PROFIT_PCT=0.06
MAX_OPEN_POSITIONS=10
MAX_LEVERAGE=1.0
MAX_PORTFOLIO_LOSS_PCT=0.10

# --- SNS ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
X_BEARER_TOKEN=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_TV_SYMBOL=TSE:7203
