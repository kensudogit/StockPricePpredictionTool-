    "echarts": "5.5.1",
    "echarts-for-react": "3.0.2",
    "next": "15.1.3",
    "react": "19.0.0",
    "react-chartjs-2": "5.3.0",
    "react-dom": "19.0.0",
    "recharts": "2.15.0"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "jsdom": "25.0.1",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
